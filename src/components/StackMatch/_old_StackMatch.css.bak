.stack-match {
  margin-top: 64px;
  padding: 36px;
  border-radius: var(--radius);
  background: var(--card);
  border: 1px solid var(--line);
  box-shadow: var(--shadow);
}

.stack-match-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.stack-match-head h2 {
  font-size: 1.5rem;
}

.stack-match-head p {
  margin-top: 6px;
  font-size: 0.92rem;
}

.stack-match-reset {
  background: var(--bg-alt);
  border: 1px solid var(--line);
  color: var(--ink);
  font-weight: 600;
  font-size: 0.85rem;
  padding: 9px 18px;
  border-radius: 999px;
  transition: background 0.15s ease, transform 0.15s ease;
  flex-shrink: 0;
}

.stack-match-reset:hover {
  background: var(--lavender);
  color: #fff;
  transform: translateY(-1px);
}

.stack-match-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

@media (max-width: 560px) {
  .stack-match-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.stack-card {
  aspect-ratio: 1;
  perspective: 800px;
  background: none;
  border: none;
  padding: 0;
}

.stack-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  display: block;
  transform-style: preserve-3d;
  transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.stack-card-flipped .stack-card-inner {
  transform: rotateY(180deg);
}

.stack-card-face {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  backface-visibility: hidden;
  font-family: var(--font-mono);
  font-weight: 500;
  text-align: center;
  padding: 6px;
}

.stack-card-back {
  background: linear-gradient(135deg, var(--lavender), var(--pink));
  color: #fff;
  font-size: 1.3rem;
  font-weight: 700;
}

.stack-card-front {
  background: var(--bg-alt);
  color: var(--ink);
  font-size: 0.8rem;
  transform: rotateY(180deg);
  border: 1.5px solid var(--teal);
}

.stack-card-matched .stack-card-front {
  background: var(--teal);
  color: #fff;
  border-color: var(--teal-deep);
}

.stack-match-status {
  margin-top: 20px;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  text-align: center;
}

@media (prefers-reduced-motion: reduce) {
  .stack-card-inner { transition: none; }
}
